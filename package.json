{
  "name": "reluxury",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "better-auth": "1.6.9",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "portless reluxury turbo -F @reluxury/infra dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @reluxury/db db:push",
    "db:generate": "turbo -F @reluxury/db db:generate",
    "deploy": "turbo -F @reluxury/infra deploy --",
    "deploy:prod": "turbo -F @reluxury/infra deploy -- --stage prod",
    "destroy": "turbo -F @reluxury/infra destroy --",
    "test": "turbo test",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@reluxury/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@reluxury/config": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "portless": "^0.13.1",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.3"
  },
  "packageManager": "bun@1.3.10"
}
